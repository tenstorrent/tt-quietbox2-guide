---
layout: layouts/base.njk
---
<div class="site-main">
  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom: 2em;">
    <a href="/{{ persona.id }}/" style="font-size:12px; color: var(--muted);">← Back to {{ persona.name }}</a>
    <button onclick="window.print()" style="background:var(--bg1);border:1px solid var(--bg2);color:var(--text2);padding:6px 14px;border-radius:var(--radius);cursor:pointer;font-size:12px;">
      Print / Save PDF
    </button>
  </div>
  {{ content | safe }}
</div>
