---
layout: layouts/read.njk
title: "ML Practitioner — Complete Guide"
personaId: ml-practitioner
permalink: /read/ml-practitioner/
---
{% set persona = personas | findPersona(personaId) %}

<div style="border-left:3px solid {{ persona.color }};padding-left:16px;margin-bottom:2em;">
  <div style="font-size:10px;letter-spacing:1.8px;text-transform:uppercase;color:var(--muted);margin-bottom:6px;">Complete Guide</div>
  <h1>{{ persona.name }}</h1>
  <p style="color:var(--text2);">{{ persona.couplet[0] }} {{ persona.couplet[1] }}</p>
  <p style="font-size:12px;color:var(--muted);margin-top:8px;">{{ persona.chapters | length }} chapters · {{ persona.chapters | readTime }} read time</p>
</div>

{% for chapter in collections.mlPractitionerChapters %}
<div class="read-chapter">
  <div class="read-chapter-number">Chapter {{ loop.index }}</div>
  {{ chapter.content | safe }}
</div>
{% endfor %}
