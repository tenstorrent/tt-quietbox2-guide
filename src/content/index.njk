---
layout: layouts/base.njk
title: QB2 Guide
isHome: true
description: "Choose your path through the Tenstorrent Quietbox 2 — from first boot to first model and beyond."
---

<section class="hero">
  <p class="hero-eyebrow">A handbook for your</p>
  <h1 class="hero-title">TT-QuietBox<sup>®</sup> 2</h1>
  <div class="hero-couplet" id="hero-couplet">
    <p>Hover a circle to see what each path covers. Click to begin.</p>
  </div>
</section>

<div class="home-layout">
<div class="venn-wrap">
  <svg class="venn-svg" viewBox="0 0 520 460" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Four overlapping paths through the QB2 Guide">
    <title>QB2 Guide Paths — choose your adventure</title>
    <!-- Four overlapping circles, each centered at persona vennCx/vennCy * 5.2 -->
    {% for p in personas %}
    <circle
      class="venn-circle"
      data-persona="{{ p.id }}"
      data-couplet-1="{{ p.couplet[0] }}"
      data-couplet-2="{{ p.couplet[1] }}"
      cx="{{ p.vennCx * 5.2 }}"
      cy="{{ p.vennCy * 5.2 }}"
      r="110"
      role="button"
      tabindex="0"
      aria-label="Enter {{ p.name }} path"
    />
    {% endfor %}

    <!-- Intersection zone labels -->
    <text class="venn-intersection-label" x="260" y="176">Install Stack</text>
    <text class="venn-intersection-label" x="200" y="200">tt-smi</text>
    <text class="venn-intersection-label" x="320" y="200">Run Models</text>
    <text class="venn-intersection-label" x="260" y="230">First Model</text>

    <!-- Persona name labels -->
    {% for p in personas %}
    <text class="venn-label"
      x="{{ p.vennCx * 5.2 + (p.vennCx < 50 and -55 or 55) }}"
      y="{{ p.vennCy * 5.2 + (p.vennCy < 50 and -80 or 80) }}"
      style="fill: {{ p.color }}">{{ p.name }}</text>
    {% endfor %}
  </svg>
</div>

<div class="persona-cards">
  {% for p in personas %}
  <a href="/{{ p.id }}/" class="persona-card" data-persona="{{ p.id }}" style="--persona-color: {{ p.color }}">
    <div class="persona-card-name">{{ p.name }}</div>
    <div class="persona-card-couplet">{{ p.couplet[0] }}</div>
    <div class="persona-card-meta">{{ p.chapters | length }} chapters · {{ p.chapters | readTime }}</div>
    <span class="persona-card-enter">Enter →</span>
  </a>
  {% endfor %}
</div>
</div>

<section class="specsheet-section">
  <div class="specsheet-wrap">
    <div class="specsheet-header">
      <div>
        <h2 class="specsheet-title">TT-QuietBox<sup>®</sup> 2</h2>
        <p class="specsheet-sub">Blackhole® · 4 chips · liquid-cooled · $9,999</p>
      </div>
      <a href="https://tenstorrent.com/hardware/tt-quietbox" class="specsheet-link" target="_blank" rel="noopener">Product page ↗</a>
    </div>

    <div class="specsheet-grid">

      <div class="specsheet-group">
        <div class="specsheet-group-label">AI Accelerator</div>
        <div class="specsheet-row"><span>Chips</span><span>4× Blackhole® P300c</span></div>
        <div class="specsheet-row"><span>Tensix cores</span><span>480 total (120 per chip)</span></div>
        <div class="specsheet-row"><span>AI clock</span><span>1.35 GHz</span></div>
        <div class="specsheet-row"><span>SRAM</span><span>720 MB total (180 MB/chip)</span></div>
        <div class="specsheet-row"><span>DRAM</span><span>128 GB GDDR6 total (32 GB/chip)</span></div>
        <div class="specsheet-row"><span>Bandwidth</span><span>1,024 GB/s per card</span></div>
        <div class="specsheet-row"><span>Chip interconnect</span><span>Warp400 (2× per card, Samtec ARP6)</span></div>
      </div>

      <div class="specsheet-group">
        <div class="specsheet-group-label">Host System</div>
        <div class="specsheet-row"><span>CPU</span><span>AMD Ryzen 7 9700X (8c, 3.8 GHz)</span></div>
        <div class="specsheet-row"><span>System RAM</span><span>256 GB DDR5-5600</span></div>
        <div class="specsheet-row"><span>Storage</span><span>4 TB NVMe PCIe Gen5</span></div>
        <div class="specsheet-row"><span>Motherboard</span><span>ASRock B850M-C</span></div>
        <div class="specsheet-row"><span>OS</span><span>Ubuntu 24.04.3 LTS</span></div>
        <div class="specsheet-row"><span>PSU</span><span>1,600 W</span></div>
        <div class="specsheet-row"><span>Peak draw</span><span>~1,500 W</span></div>
      </div>

      <div class="specsheet-group">
        <div class="specsheet-group-label">Connectivity</div>
        <div class="specsheet-row"><span>Display</span><span>1× HDMI</span></div>
        <div class="specsheet-row"><span>USB</span><span>8× (2× Gen2, 2× Gen1, 4× USB 2.0)</span></div>
        <div class="specsheet-row"><span>LAN</span><span>Gigabit Ethernet</span></div>
        <div class="specsheet-row"><span>WiFi</span><span>Wi-Fi 6 (802.11ax) dual-band</span></div>
        <div class="specsheet-row"><span>Bluetooth</span><span>5.3</span></div>
      </div>

      <div class="specsheet-group">
        <div class="specsheet-group-label">Physical</div>
        <div class="specsheet-row"><span>Dimensions</span><span>9.1 × 17.8 × 15.6 in</span></div>
        <div class="specsheet-row"><span>Weight</span><span>20 kg / 44 lbs</span></div>
        <div class="specsheet-row"><span>Cooling</span><span>Liquid (38 dBA max)</span></div>
        <div class="specsheet-row"><span>Operating temp</span><span>10–35°C (50–95°F)</span></div>
      </div>

    </div>

    <p class="specsheet-source">Source: <a href="https://docs.tenstorrent.com/systems/quietbox/quietbox-bh-2/specifications.html" target="_blank" rel="noopener">docs.tenstorrent.com — TT-QuietBox 2 Specifications</a></p>
  </div>
</section>

{% if compatibility.models.length > 0 %}
<section class="compat-section">
  <div class="compat-header">
    <h2 class="compat-title">What's Running on QB2</h2>
    <p class="compat-subtitle">Live from the Tenstorrent compatibility matrix — models confirmed or in testing on Quietbox 2 / P150 / P300c hardware.</p>
    {% if compatibility.generatedAt %}
    <p class="compat-updated">Updated {{ compatibility.generatedAt | replace("T", " ") | truncate(16, true, "") }} UTC</p>
    {% endif %}
  </div>

  <div class="compat-grid">
    {% for model in compatibility.models %}
    <a href="{{ model.link }}" class="compat-card compat-card--{{ model.status | lower }}" target="_blank" rel="noopener">
      <div class="compat-card-top">
        <span class="compat-status compat-status--{{ model.status | lower }}">{{ model.status }}</span>
        {% if model.task %}<span class="compat-task">{{ model.task }}</span>{% endif %}
      </div>
      <div class="compat-card-name">{{ model.name }}</div>
      {% if model.size %}<div class="compat-card-size">{{ model.size }}</div>{% endif %}
      {% if model.description %}
      <div class="compat-card-desc">{{ model.description | truncate(90) }}</div>
      {% endif %}
      <div class="compat-card-footer">
        {% for sw in model.software %}<span class="compat-sw">{{ sw }}</span>{% endfor %}
      </div>
    </a>
    {% endfor %}
  </div>
</section>
{% endif %}
